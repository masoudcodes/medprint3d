# Copy this to .env and fill in real values before deploying

# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-string-50-chars-minimum
ALLOWED_HOSTS=medtechprint3d.com,www.medtechprint3d.com

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=medical3dprint
DB_USER=postgres
DB_PASSWORD=replace-with-strong-password
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# File retention — delete scans older than this many days (default 120 = 4 months)
SCAN_RETENTION_DAYS=120

# Email (optional — use for doctor notifications)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-app-password
